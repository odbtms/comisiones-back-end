# Copiá este archivo como .env y completá los valores.
# .env NO se sube al repo (está en .gitignore).

DB_NAME=comisiones
DB_USER=comisiones
DB_PASSWORD=cambia-esta-clave

# Secreto para firmar los JWT del login. DEBE ser largo (>= 32 bytes / 32+ caracteres).
# Generá uno con:  openssl rand -base64 48
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-de-32-bytes-o-mas

# Origen(es) del front permitidos por CORS, separados por coma.
CORS_ORIGINS=http://localhost:5173
